# ===================== AI Provider =====================
# Pick one: gemini | vertex | deepseek | claude
# - gemini   : Google AI Studio (single API key — easiest, free tier available)
# - vertex   : Google Vertex AI (uses GCP billing — best for burning $300 credit)
# - deepseek : Cheap, OpenAI-compatible
# - claude   : High quality, higher cost
AI_PROVIDER=gemini

# --- Google Gemini (AI Studio) ---
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Google Vertex AI ---
# 1) Enable Vertex AI API on your GCP project
# 2) Create a service account with role "roles/aiplatform.user"
# 3) Download the JSON key, put it on the server, set the path below
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
# Vertex requires either a fully-versioned id (e.g. gemini-2.0-flash-001)
# or a GA alias (e.g. gemini-2.5-flash). Plain "gemini-2.0-flash" will 404.
VERTEX_MODEL=gemini-2.5-flash
# Path to the service-account JSON key. Leave blank for local dev (uses
# `gcloud auth application-default login` credentials automatically).
GOOGLE_APPLICATION_CREDENTIALS=

# --- DeepSeek (OpenAI-compatible API) ---
# Get a key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# --- Anthropic Claude ---
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-5

# ===================== Server =====================
HOST=127.0.0.1
PORT=8765

# ===================== Auth =====================
# Leave blank for local dev (auth disabled).
# For any public deployment, generate a long random token, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
AUTH_TOKEN=

# ===================== Database (optional) =====================
# DATABASE_PATH=./data/tracker.db
